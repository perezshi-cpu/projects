---
---
<section
  id="hero"
  dir="rtl"
  lang="he"
  style="position:relative;height:100vh;min-height:600px;display:flex;align-items:center;justify-content:center;overflow:hidden;background:#0a0a0f;"
>
  <!-- Video background -->
  <video
    autoplay
    muted
    loop
    playsinline
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;pointer-events:none;"
  >
    <source src="/hero-bg.mp4" type="video/mp4" />
  </video>

  <!-- Radial gradient overlay -->
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 50% 40%, rgba(22,33,62,0.5) 0%, rgba(10,10,15,0.7) 60%, #0a0a0f 100%);pointer-events:none;"></div>

  <!-- Blob 1 — purple, top-left -->
  <div
    style="position:absolute;top:10%;left:5%;width:32rem;height:32rem;border-radius:9999px;background:rgba(107,33,168,0.2);filter:blur(96px);pointer-events:none;animation:float 7s ease-in-out infinite;"
  ></div>

  <!-- Blob 2 — cyan, bottom-right -->
  <div
    style="position:absolute;bottom:10%;right:5%;width:24rem;height:24rem;border-radius:9999px;background:rgba(0,229,255,0.07);filter:blur(96px);pointer-events:none;animation:float 11s ease-in-out infinite;animation-delay:-5s;"
  ></div>

  <!-- Content -->
  <div style="position:relative;z-index:10;text-align:center;padding:0 1.5rem;max-width:56rem;margin:0 auto;animation:fadeInUp 1s ease-out both;">
    <!-- Date & Location pill -->
    <p style="font-family:var(--font-display);font-size:0.75rem;font-weight:600;letter-spacing:0.2em;text-transform:uppercase;color:var(--color-cyan-neon);margin-bottom:1.5rem;">
      17–19 בספטמבר 2026 &nbsp;·&nbsp; נווה מדבר שיטים
    </p>

    <!-- Main title -->
    <h1 style="font-family:var(--font-display);font-weight:800;line-height:1;margin-bottom:1.5rem;">
      <span class="text-gradient-cyan-magenta" style="display:block;font-size:clamp(3rem,11vw,7.5rem);">MATAN'A</span>
      <span style="display:block;font-size:clamp(1.25rem,3vw,2rem);font-weight:500;color:rgba(255,255,255,0.5);letter-spacing:0.3em;margin-top:0.5rem;">FESTIVAL</span>
    </h1>

    <!-- Tagline -->
    <p style="font-family:var(--font-body);font-size:clamp(1rem,2vw,1.25rem);color:rgba(255,255,255,0.6);margin-bottom:2.5rem;max-width:36rem;margin-left:auto;margin-right:auto;">
      היכן שהצליל פוגש את המדבר
    </p>

    <!-- CTA buttons -->
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <a href="#lineup" class="btn-ghost">לצפייה בסדר ההופעות</a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div style="position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:0.5rem;animation:fadeInUp 1s ease-out 0.5s both;">
    <span style="font-family:var(--font-display);font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;color:rgba(255,255,255,0.3);">גללו למטה</span>
    <svg width="16" height="24" viewBox="0 0 16 24" fill="none" style="animation:float 2s ease-in-out infinite;">
      <rect x="6" y="2" width="4" height="8" rx="2" fill="rgba(0,229,255,0.6)"/>
      <rect x="5" y="0" width="6" height="16" rx="3" stroke="rgba(255,255,255,0.2)" stroke-width="1.5" fill="none"/>
    </svg>
  </div>
</section>

