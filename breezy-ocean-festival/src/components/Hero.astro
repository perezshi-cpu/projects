---
---
<section
  id="hero"
  dir="rtl"
  lang="he"
  style="position:relative;height:100vh;min-height:600px;display:flex;align-items:center;justify-content:center;overflow:hidden;background:#0a0a0f;"
>
  <!-- Video background -->
  <video
    autoplay
    muted
    loop
    playsinline
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;pointer-events:none;"
  >
    <source src="/hero-bg.mp4" type="video/mp4" />
  </video>

  <!-- Radial gradient overlay -->
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 50% 40%, rgba(22,33,62,0.5) 0%, rgba(10,10,15,0.7) 60%, #0a0a0f 100%);pointer-events:none;"></div>

  <!-- Blob 1 — purple, top-left -->
  <div
    style="position:absolute;top:10%;left:5%;width:32rem;height:32rem;border-radius:9999px;background:rgba(107,33,168,0.2);filter:blur(96px);pointer-events:none;animation:float 7s ease-in-out infinite;"
  ></div>

  <!-- Blob 2 — cyan, bottom-right -->
  <div
    style="position:absolute;bottom:10%;right:5%;width:24rem;height:24rem;border-radius:9999px;background:rgba(0,229,255,0.07);filter:blur(96px);pointer-events:none;animation:float 11s ease-in-out infinite;animation-delay:-5s;"
  ></div>

  <!-- Content -->
  <div style="position:relative;z-index:10;text-align:center;padding:0 1.5rem;max-width:56rem;margin:0 auto;animation:fadeInUp 1s ease-out both;">
    <!-- Date & Location pill -->
    <p style="font-family:var(--font-display);font-size:0.75rem;font-weight:600;letter-spacing:0.2em;text-transform:uppercase;color:var(--color-cyan-neon);margin-bottom:1.5rem;">
      17–19 בספטמבר 2026 &nbsp;·&nbsp; נווה מדבר שיטים
    </p>

    <!-- Main title -->
    <h1 style="font-family:var(--font-display);font-weight:800;line-height:1;margin-bottom:1.5rem;">
      <span class="text-gradient-cyan-magenta" style="display:block;font-size:clamp(3rem,11vw,7.5rem);">MATAN'A</span>
      <span style="display:block;font-size:clamp(1.25rem,3vw,2rem);font-weight:500;color:rgba(255,255,255,0.5);letter-spacing:0.3em;margin-top:0.5rem;">FESTIVAL</span>
    </h1>

    <!-- Tagline -->
    <p style="font-family:var(--font-body);font-size:clamp(1rem,2vw,1.25rem);color:rgba(255,255,255,0.6);margin-bottom:2.5rem;max-width:36rem;margin-left:auto;margin-right:auto;">
      היכן שהצליל פוגש את המדבר
    </p>

    <!-- Countdown (mobile, in-flow) -->
    <div id="countdown-mobile" class="countdown-inline">
      <p class="countdown-label">עד תחילת המסע</p>
      <div class="countdown-tiles">
        <div class="card-glass countdown-tile">
          <span class="countdown-value" data-unit="days">00</span>
          <span class="countdown-unit">ימים</span>
        </div>
        <div class="card-glass countdown-tile">
          <span class="countdown-value" data-unit="hours">00</span>
          <span class="countdown-unit">שעות</span>
        </div>
        <div class="card-glass countdown-tile">
          <span class="countdown-value" data-unit="minutes">00</span>
          <span class="countdown-unit">דקות</span>
        </div>
        <div class="card-glass countdown-tile">
          <span class="countdown-value" data-unit="seconds">00</span>
          <span class="countdown-unit">שניות</span>
        </div>
      </div>
    </div>

    <!-- CTA buttons -->
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <a href="#lineup" class="btn-ghost">לצפייה בהופעות</a>
    </div>
  </div>

  <!-- Countdown -->
  <div id="countdown" class="countdown">
    <p class="countdown-label">עד תחילת המסע</p>
    <div class="countdown-tiles">
      <div class="card-glass countdown-tile">
        <span class="countdown-value" data-unit="days">00</span>
        <span class="countdown-unit">ימים</span>
      </div>
      <div class="card-glass countdown-tile">
        <span class="countdown-value" data-unit="hours">00</span>
        <span class="countdown-unit">שעות</span>
      </div>
      <div class="card-glass countdown-tile">
        <span class="countdown-value" data-unit="minutes">00</span>
        <span class="countdown-unit">דקות</span>
      </div>
      <div class="card-glass countdown-tile">
        <span class="countdown-value" data-unit="seconds">00</span>
        <span class="countdown-unit">שניות</span>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div style="position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:0.5rem;animation:fadeInUp 1s ease-out 0.5s both;">
    <span style="font-family:var(--font-display);font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;color:rgba(255,255,255,0.3);">גללו למטה</span>
    <svg width="16" height="24" viewBox="0 0 16 24" fill="none" style="animation:float 2s ease-in-out infinite;">
      <rect x="6" y="2" width="4" height="8" rx="2" fill="rgba(0,229,255,0.6)"/>
      <rect x="5" y="0" width="6" height="16" rx="3" stroke="rgba(255,255,255,0.2)" stroke-width="1.5" fill="none"/>
    </svg>
  </div>
</section>

<script>
  // Music starts Sep 17, 2026, 17:00 Asia/Jerusalem (IDT, UTC+3 in September 2026).
  // Fixed one-time constant — unlike Schedule.astro's getIsraelNowTimeKey (which must
  // repeatedly re-derive "current Israel wall-clock time" every tick to match against
  // schedule slots), this target instant never changes, so baking in the +03:00 offset
  // once is correct and needs no ongoing DST-tracking logic.
  const COUNTDOWN_TARGET_MS = new Date('2026-09-17T17:00:00+03:00').getTime();

  const countdownEls = [document.getElementById('countdown'), document.getElementById('countdown-mobile')]
    .filter((el): el is HTMLElement => el !== null);

  const valueEls = {
    days: Array.from(document.querySelectorAll<HTMLElement>('[data-unit="days"]')),
    hours: Array.from(document.querySelectorAll<HTMLElement>('[data-unit="hours"]')),
    minutes: Array.from(document.querySelectorAll<HTMLElement>('[data-unit="minutes"]')),
    seconds: Array.from(document.querySelectorAll<HTMLElement>('[data-unit="seconds"]')),
  };

  function pad(n: number): string {
    return String(n).padStart(2, '0');
  }

  function setText(els: HTMLElement[], text: string) {
    els.forEach(el => { el.textContent = text; });
  }

  let countdownInterval: ReturnType<typeof setInterval> | undefined;

  function updateCountdown() {
    if (countdownEls.length === 0) return;

    const remainingMs = COUNTDOWN_TARGET_MS - Date.now();

    if (remainingMs <= 0) {
      countdownEls.forEach(el => { el.style.display = 'none'; });
      if (countdownInterval !== undefined) {
        clearInterval(countdownInterval);
        countdownInterval = undefined;
      }
      return;
    }

    const totalSeconds = Math.floor(remainingMs / 1000);
    const days = Math.floor(totalSeconds / 86400);
    const hours = Math.floor((totalSeconds % 86400) / 3600);
    const minutes = Math.floor((totalSeconds % 3600) / 60);
    const seconds = totalSeconds % 60;

    setText(valueEls.days, pad(days));
    setText(valueEls.hours, pad(hours));
    setText(valueEls.minutes, pad(minutes));
    setText(valueEls.seconds, pad(seconds));
  }

  updateCountdown();
  countdownInterval = setInterval(updateCountdown, 1000);
</script>

<style>
  .countdown {
    position: absolute;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 10;
    text-align: center;
    animation: fadeInUp 1s ease-out 0.3s both;
  }
  .countdown-inline {
    display: none;
  }
  .countdown-label {
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: 0.5rem;
  }
  .countdown-tiles {
    display: flex;
    flex-direction: row-reverse;
    justify-content: center;
    gap: 0.4rem;
  }
  .countdown-tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0.4rem 0.55rem;
    min-width: 2.75rem;
  }
  .countdown-value {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--color-cyan-neon);
    animation: var(--animate-glow-pulse);
    line-height: 1;
  }
  .countdown-unit {
    font-family: var(--font-display);
    font-size: 0.55rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin-top: 0.2rem;
  }
  @media (max-width: 640px) {
    #countdown {
      display: none;
    }
    .countdown-inline {
      display: block;
      margin: 0 auto 2rem;
    }
    .countdown-inline .countdown-tile {
      padding: 0.5rem 0.7rem;
      min-width: 3.5rem;
    }
    .countdown-inline .countdown-value {
      font-size: 1.3rem;
    }
    .countdown-inline .countdown-unit {
      font-size: 0.6rem;
    }
  }
</style>

