---
export interface Props {
  name: string;
  origin: string;
  genre: string;
  day: string;
  stage: string;
  time: string;
  photo?: string;
  headliner?: boolean;
}

const { name, day, photo } = Astro.props;

// Fallback gradient if no photo
const hue = (name.charCodeAt(0) * 37 + name.charCodeAt(name.length - 1) * 13) % 360;
const hue2 = (hue + 60) % 360;
const initials = name.split(' ').map(w => w[0]).join('').slice(0, 2).toUpperCase();
---

<div class="card-glass artist-card">
  <!-- Photo or gradient fallback -->
  <div class="card-img-wrap">
    {photo
      ? <img src={photo} alt={name} class="card-img" />
      : <div class="card-img-fallback" style={`background:conic-gradient(from 180deg at 50% 60%, hsl(${hue},70%,30%), hsl(${hue2},60%,20%), hsl(${hue},80%,15%));`}>
          <span class="card-initials" style={`color:hsl(${hue},80%,75%);`}>{initials}</span>
        </div>
    }
  </div>

  <!-- Card body -->
  <div class="card-body">
    <h3 class="card-name">{name}</h3>
    <span class="meta-day">{day}</span>
  </div>
</div>

<style>
  .artist-card {
    position: relative;
    overflow: hidden;
    cursor: default;
  }
  .card-img-wrap {
    height: 11rem;
    overflow: hidden;
    position: relative;
  }
  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: transform 0.4s ease;
  }
  .artist-card:hover .card-img {
    transform: scale(1.05);
  }
  .card-img-fallback {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .card-initials {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 800;
    opacity: 0.7;
    user-select: none;
  }
  .card-body {
    padding: 1rem;
  }
  .card-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    color: white;
    margin-bottom: 0.25rem;
  }
  .meta-day { font-size: 0.65rem; font-family: var(--font-display); font-weight: 600; color: var(--color-gold-warm); opacity: 0.8; }
</style>
