---
import { artists } from '../data/artists';
import ArtistCard from './ArtistCard.astro';
import ArtistModal from './ArtistModal.astro';

const performers = artists.filter(a => !a.isBreak && !a.scheduleOnly);
---

<section id="lineup" class="lineup-section" dir="rtl" lang="he">
  <div class="lineup-inner">
    <!-- Section header -->
    <div class="lineup-header">
      <p class="section-label">אמנים</p>
      <h2 class="lineup-title">
        <span class="text-gradient-cyan-magenta">סדר הופעות 2026</span>
      </h2>
      <p class="lineup-subtitle">
        שלושה לילות של פסיטראנס על הבמה הראשית בנווה המדבר שיטים.
      </p>
    </div>

    <!-- Artist grid -->
    <div class="artist-grid">
      {performers.map(artist => <ArtistCard {...artist} />)}
    </div>
  </div>

  <ArtistModal />
</section>

<style>
  .lineup-section {
    padding: 6rem 1.5rem;
    position: relative;
  }
  .lineup-inner {
    max-width: 80rem;
    margin: 0 auto;
  }
  .lineup-header {
    text-align: center;
    margin-bottom: 4rem;
  }
  .section-label {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    margin-bottom: 0.75rem;
  }
  .lineup-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    margin-bottom: 1rem;
  }
  .lineup-subtitle {
    font-size: 1rem;
    color: rgba(255,255,255,0.45);
    max-width: 32rem;
    margin: 0 auto;
  }
  .artist-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  @media (min-width: 640px) {
    .artist-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 1024px) {
    .artist-grid { grid-template-columns: repeat(4, 1fr); }
  }
</style>
