---
import { stages, timeSlots } from '../data/schedule';
import type { Artist } from '../data/artists';
import { stageLabels } from '../lib/hebrewLabels';

export interface Props {
  entries: Artist[];
}
const { entries } = Astro.props;

// Only show time slots that have at least one entry on this day
const activeSlots = timeSlots.filter(slot =>
  entries.some(e => e.time === slot)
);
---

<div class="schedule-table-wrap">
  <table class="schedule-table">
    <thead>
      <tr>
        <th class="time-col">שעה</th>
        {stages.map(s => <th class="stage-col">{stageLabels[s] ?? s}</th>)}
      </tr>
    </thead>
    <tbody>
      {activeSlots.map(slot => {
        const rowEntries = stages.map(stage => entries.find(e => e.stage === stage && e.time === slot) ?? null);
        return (
          <tr class="schedule-row">
            <td class="time-cell">{slot}</td>
            {rowEntries.map(entry => (
              <td class="entry-cell">
                {entry && !entry.isBreak && (
                  <div class="entry-card">
                    <p class="entry-name">{entry.name}</p>
                  </div>
                )}
                {entry?.isBreak && (
                  <div class="entry-break">
                    <p class="break-label">הפסקה</p>
                    <p class="break-time">{entry.genre}</p>
                  </div>
                )}
              </td>
            ))}
          </tr>
        );
      })}
    </tbody>
  </table>
</div>

<style>
  .schedule-table-wrap { overflow-x: auto; }
  .schedule-table {
    width: 100%;
    min-width: 400px;
    border-collapse: collapse;
  }
  th {
    padding: 0.75rem 1rem;
    text-align: start;
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .time-col { width: 5rem; color: rgba(255,255,255,0.25); }
  .stage-col { color: var(--color-cyan-neon); }
  .schedule-row { border-top: 1px solid rgba(255,255,255,0.05); }
  .time-cell {
    padding-block: 0.75rem;
    padding-inline-end: 1rem;
    padding-inline-start: 0;
    font-family: monospace;
    font-size: 0.75rem;
    color: rgba(255,255,255,0.3);
    white-space: nowrap;
  }
  .entry-cell { padding: 0.5rem; }
  .entry-card {
    padding: 0.75rem;
    border-radius: 0.5rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    transition: all 0.2s;
  }
  .entry-card:hover {
    background: rgba(255,255,255,0.07);
    border-color: rgba(0,229,255,0.2);
  }
  .entry-headliner {
    background: rgba(255,0,200,0.06);
    border-color: rgba(255,0,200,0.2);
  }
  .entry-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.875rem;
    color: white;
    margin-bottom: 0.2rem;
  }
  .entry-genre {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.4);
  }
  .entry-break {
    padding: 0.75rem;
    border-radius: 0.5rem;
    background: rgba(255,215,0,0.04);
    border: 1px dashed rgba(255,215,0,0.2);
    text-align: center;
  }
  .break-label {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.875rem;
    color: var(--color-gold-warm);
    opacity: 0.7;
    margin-bottom: 0.2rem;
  }
  .break-time {
    font-size: 0.7rem;
    color: rgba(255,215,0,0.4);
  }
</style>
